-- 4. ตรรกะฟาร์มหลัก
-- ==========================================
local function startAutoFarm()
    while task.wait(waitDelay) do
        if not trainerEnabled or not screenGui.Parent then continue end
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            if not lockedCFrame then lockedCFrame = character.HumanoidRootPart.CFrame
            else character.HumanoidRootPart.CFrame = lockedCFrame end
            
            for i = 1, farmSpeedMultiplier do
                task.spawn(function()
                    pcall(function()
                        ReqUpdateTrainSpeed:InvokeServer(6)
                        ReqClickTrain:InvokeServer()
                    end)
                end)
            end
        else
            lockedCFrame = nil
        end
    end
end
task.spawn(startAutoFarm)

-- ==========================================
-- 5. ตรรกะสลับสเตตัสอัตโนมัติ (Train All แบบสุ่มดีเลย์เนียนๆ)
-- ==========================================
local statCycle = {5, 6, 7, 8}
local currentCycleIndex = 1

task.spawn(function()
    while true do 
        local randomDelay = math.random(11, 18) / 10 
        task.wait(randomDelay)
        
        if trainerEnabled and trainAllEnabled and screenGui.Parent then
            currentCycleIndex = currentCycleIndex + 1
            if currentCycleIndex > #statCycle then currentCycleIndex = 1 end
            local statToTrain = statCycle[currentCycleIndex]
            pcall(function()
                ReqApplyEquipTrainMethod:InvokeServer(statToTrain)
            end)
        end
    end
end)

