local function updateStatusLabel()
    currentStatusLabel.Text = string.format("Status: %s | Area: %s", trainerEnabled and "Farming" or "Idle", currentArea)
end

local function exitCurrentArea()
    if currentArea == "150%" then
		-- [อัปเดต] เช็กเผ่าก่อนออก เพื่อเลือกลบโฟลเดอร์ให้ถูกฝั่ง
		local target150Folder = (currentFactionId == 4) and BonusAreaFolder or BonusAreaHumanFolder
        for _, id in ipairs({"1", "2", "7"}) do task.spawn(function() pcall(function() ReqExitArea:FireServer(target150Folder:FindFirstChild(id), LocalPlayer.Character, 7) end) end) end
    elseif currentArea == "300%" then
		-- [อัปเดต] เปลี่ยนเป็น ID 1 และ 4 ตาม Log ล่าสุด
        for _, id in ipairs({"1", "4"}) do task.spawn(function() pcall(function() ReqExitArea:FireServer(CapturableAreaFolder:FindFirstChild(id), LocalPlayer.Character, 6) end) end) end
    end
end

local function setGhostArea(target)
    exitCurrentArea() 
    ghost150Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50); ghost150Button.Text = "150% Area: OFF"
    ghost300Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50); ghost300Button.Text = "300% Area: OFF"
    
    if target == "150" then
        currentArea = "150%"; ghost150Button.BackgroundColor3 = Color3.fromRGB(50, 150, 50); ghost150Button.Text = "150% Area: ON"
		-- [อัปเดต] เลือกมุดโฟลเดอร์ตามเผ่าปัจจุบัน
		local target150Folder = (currentFactionId == 4) and BonusAreaFolder or BonusAreaHumanFolder
        for _, id in ipairs({"1", "2", "7"}) do task.spawn(function() pcall(function() ReqEnterArea:FireServer(target150Folder:FindFirstChild(id), LocalPlayer.Character, 7) end) end) end
    elseif target == "300" then
        currentArea = "300%"; ghost300Button.BackgroundColor3 = Color3.fromRGB(50, 150, 50); ghost300Button.Text = "300% Area: ON"
		-- [อัปเดต] เปลี่ยนเป็น ID 1 และ 4 ตาม Log ล่าสุด
        for _, id in ipairs({"1", "4"}) do task.spawn(function() pcall(function() ReqEnterArea:FireServer(CapturableAreaFolder:FindFirstChild(id), LocalPlayer.Character, 6) end) end) end
    else currentArea = "Normal" end
    updateStatusLabel()
end

